{
    "name": "@plurid/youtube-side",
    "version": "0.0.5",
    "description": "Chrome Extension for YouTube Side",
    "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
    "keywords": [
        "youtube",
        "chrome",
        "extension"
    ],
    "license": "DEL",
    "private": true,
    "type": "commonjs",
    "packageManager": "pnpm@11.15.1",
    "engines": {
        "node": ">=24"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/plurid/youtube-side"
    },
    "bugs": {
        "url": "https://github.com/plurid/youtube-side/issues"
    },
    "homepage": "https://github.com/plurid/youtube-side",
    "files": [
        "distribution/"
    ],
    "scripts": {
        "clean": "node scripts/clean.mjs",
        "format": "biome check --write .",
        "lint": "biome ci .",
        "typecheck": "tsc --noEmit",
        "test": "jest --runInBand",
        "test:coverage": "jest --runInBand --coverage",
        "build:development": "pnpm clean && webpack --mode development",
        "build": "pnpm clean && webpack --mode production",
        "verify:build": "node scripts/verify-build.mjs",
        "package": "pnpm build && node scripts/package.mjs && pnpm verify:build",
        "distribute": "pnpm package",
        "check": "pnpm peers check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm package"
    },
    "dependencies": {
        "@plurid/plurid-icons-react": "0.0.0-10",
        "@plurid/plurid-themes": "0.0.0-3",
        "@plurid/plurid-ui-components-react": "0.0.0-34",
        "react": "19.2.8",
        "react-dom": "19.2.8",
        "styled-components": "6.4.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.5",
        "@jest/globals": "30.4.1",
        "@testing-library/jest-dom": "7.0.0",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/archiver": "8.0.0",
        "@types/chrome": "0.2.2",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "archiver": "8.0.0",
        "copy-webpack-plugin": "14.0.0",
        "html-webpack-plugin": "5.6.7",
        "jest": "30.4.2",
        "jest-environment-jsdom": "30.4.1",
        "terser-webpack-plugin": "5.6.1",
        "ts-jest": "29.4.12",
        "ts-loader": "9.6.2",
        "typescript": "6.0.3",
        "webpack": "5.108.4",
        "webpack-cli": "7.2.1"
    }
}
